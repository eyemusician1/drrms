MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/drrms_db
DB_NAME=drrms_db
JWT_SECRET=your-64-char-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_ENV=development
APP_NAME=DRRMS API
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=10
SECURE_HEADERS=true
